<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        Account settings - FreeMD
    </title>
    <link rel="stylesheet" href="/static/css/style.css">
    <link rel="stylesheet" href="/static/css/user.css">
</head>
<body>
    <header>
        <div id="header-left">
            <h1 id="header-title" onclick="window.location.href = '/'">FreeMD</h1>
        </div>
    </header>
    <div id="user">
    <div id="user-info-row">
        <div>
            <h1 id="username">{{username}}</h1>
            <p id="created-at">Account created at: {{created_at}}</p>
        </div>
    </div>
</div>
    <div id="settings">
        <h1 id="title">Account settings</h1>
        <div id="actions">
            <form action="/api/change-username" method="post">
                <p>Username:</p>
                <input type="text" id="change-username" name="username" placeholder="Enter new username" value="{{username}}" required>
                <button id="save">Save</button>
                {{#if error}}
                    <p id="error">{{error}}</p>
                {{/if}}
            </form>
            <button id="change-password" class="settings-button" onclick="window.location.href = '/account-settings/change-password'">Change password</button>
            <form action="/api/logout" method="POST" style="display: inline;">
                <button type="submit" id="logout" class="settings-button">Logout</button>
            </form>
            <form action="/api/delete_account" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure that you want to delete account? This action can not be canceled later.');">
                <button type="submit" id="delete" class="settings-button">Delete account</button>
            </form>
        </div>
    </div>
</body>
</html>